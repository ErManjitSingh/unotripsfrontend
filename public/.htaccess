# Apache static export — SPA routes + Hotels API proxy (signup/login/bookings).
# Enable: a2enmod rewrite proxy proxy_http

<IfModule mod_rewrite.c>
  Options -MultiViews
  RewriteEngine On
  RewriteBase /
</IfModule>

<IfModule mod_proxy.c>
  ProxyPreserveHost Off
  ProxyPass /api/hotels/ https://unohotels-backend.onrender.com/
  ProxyPassReverse /api/hotels/ https://unohotels-backend.onrender.com/
</IfModule>

<IfModule mod_rewrite.c>
  # Fallback when ProxyPass is unavailable
  <IfModule mod_proxy.c>
    RewriteRule ^api/hotels/(.*)$ https://unohotels-backend.onrender.com/$1 [P,L]
  </IfModule>

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
</IfModule>
