# Laravel CMS (blogs, destinations, testimonials only)
NEXT_PUBLIC_API_URL=https://website.travelwithuno.com

# Uno Hotels backend — hotels + packages (server-side direct)
HOTELS_API_URL=https://unohotels-backend.onrender.com
NEXT_PUBLIC_HOTELS_API_URL=https://unohotels-backend.onrender.com

# Browser uses Next.js proxy for hotels/packages API (never call Render URL directly in components)
NEXT_PUBLIC_API_BASE=/api/hotels

# Canonical site URL for metadata, Open Graph, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://unotrips.com

# Razorpay public key (from Razorpay dashboard — safe for browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
