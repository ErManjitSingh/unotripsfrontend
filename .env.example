# Laravel / CMS (blogs, packages) — NOT the hotels API
NEXT_PUBLIC_API_URL=https://website.travelwithuno.com

# Hotels API — server-side only (Next.js Route Handler proxy target)
HOTELS_API_URL=https://unohotels-backend.onrender.com

# Browser MUST use this proxy path only (never call Render URL directly)
NEXT_PUBLIC_API_BASE=/api/hotels

# Legacy alias (server scripts / prebuild)
NEXT_PUBLIC_HOTELS_API_URL=https://unohotels-backend.onrender.com

# Canonical site URL for metadata, Open Graph, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://unotrips.com
