# Copy to .env.production before npm run build for live deploy.
# Do NOT use localhost — it gets baked into SEO metadata.

NEXT_PUBLIC_SITE_URL=https://unotrips.com
NEXT_PUBLIC_API_URL=https://website.travelwithuno.com
HOTELS_API_URL=http://localhost:8000
NEXT_PUBLIC_HOTELS_API_URL=http://localhost:8000
# Browser MUST use proxy — never call Render URL directly from components
NEXT_PUBLIC_API_BASE=/api/hotels
